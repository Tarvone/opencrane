node_modules/
dist/
.angular/
.env
.env.*
!.env.example

# Secrets / credentials — never commit key material (it must flow via k8s existingSecret).
# The leaked Zitadel SA key was a *.json service-account key; block that shape + common kinds.
*.pem
*.key
*-key.json
*service-account*.json
*serviceaccount*.json
*credentials*.json
kubeconfig
*.kubeconfig

coverage/
.DS_Store
*.tsbuildinfo
.turbo/
.vscode/
.idea/
*.log
__pycache__/
*.py[cod]

# Dev (root-level scratch dir only; anchored so it doesn't swallow nested dirs
# like apps/_infra/deploy-k8s/platform/terraform/environments/dev/)
/dev/

# Claude Code local review-gate state
.claude/.last-review-hash
.claude/.review-context.md
.nx/

# Private agent review artifacts and R0 secured evidence packs.
/.agent-reviews/
/.r0-estate-evidence*/
/.r0-evidence*/
