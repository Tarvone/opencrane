{
  "name": "deploy-k8s",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["type:app", "layer:entrypoint", "scope:deployment"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "bash apps/_infra/deploy-k8s/platform/tests/server-key-permissions-contract.sh" }
    },
    "helm-lint": {
      "executor": "nx:run-commands",
      "options": { "command": "helm lint apps/_infra/deploy-k8s" }
    },
    "dependency-status": {
      "executor": "nx:run-commands",
      "options": { "command": "helm dependency list apps/_infra/deploy-k8s" }
    }
  }
}
