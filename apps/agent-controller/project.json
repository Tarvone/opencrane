{
  "name": "agent-controller",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/agent-controller/src",
  "tags": ["type:app", "layer:entrypoint", "scope:agent-controller"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/agent-controller"],
      "options": { "command": "rm -rf dist/apps/agent-controller && esbuild apps/agent-controller/src/index.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/apps/agent-controller/index.js" }
    },
    "lint": { "executor": "nx:run-commands", "options": { "command": "tsc -p tsconfig.json --noEmit", "cwd": "apps/agent-controller" } },
    "test": { "executor": "nx:run-commands", "options": { "command": "vitest run", "cwd": "apps/agent-controller" } },
    "helm-lint": { "executor": "nx:run-commands", "options": { "command": "helm lint apps/agent-controller/helm" } },
    "container": { "executor": "nx:run-commands", "options": { "command": "docker build -f apps/agent-controller/deploy/Dockerfile ." } }
  }
}
