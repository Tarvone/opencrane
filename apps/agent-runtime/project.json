{
  "name": "agent-runtime",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/agent-runtime/src",
  "tags": ["type:app", "layer:entrypoint", "scope:agent-runtime"],
  "targets": {
    "build": { "executor": "nx:run-commands", "options": { "command": "python3 -B -c 'import ast, pathlib; ast.parse(pathlib.Path(\"src/runtime.py\").read_text())'", "cwd": "apps/agent-runtime" } },
    "lint": { "executor": "nx:run-commands", "options": { "command": "python3 -B -c 'import ast, pathlib; ast.parse(pathlib.Path(\"src/runtime.py\").read_text())'", "cwd": "apps/agent-runtime" } },
    "test": { "executor": "nx:run-commands", "options": { "command": "python3 -B -m unittest discover -s tests", "cwd": "apps/agent-runtime" } },
    "container": { "executor": "nx:run-commands", "options": { "command": "docker build -f apps/agent-runtime/deploy/Dockerfile ." } }
  }
}
