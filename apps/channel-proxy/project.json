{
  "name": "channel-proxy",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/channel-proxy/src",
  "tags": ["type:app", "layer:entrypoint", "scope:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/channel-proxy"],
      "options": { "command": "rm -rf dist/apps/channel-proxy && esbuild apps/channel-proxy/src/index.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/apps/channel-proxy/index.js" }
    },
    "lint": { "executor": "nx:run-commands", "options": { "command": "tsc -p tsconfig.json --noEmit", "cwd": "apps/channel-proxy" } },
    "helm-lint": { "executor": "nx:run-commands", "options": { "command": "helm lint apps/channel-proxy/helm" } },
    "container": { "executor": "nx:run-commands", "options": { "command": "docker build -f apps/channel-proxy/deploy/Dockerfile ." } }
  }
}
