enum ArtifactKind {
  Document  @map("document")
  Generated @map("generated")
  Skill     @map("skill")
  Upload    @map("upload")
}

enum ArtifactState {
  Active          @map("active")
  DeletionPending @map("deletion_pending")
  Deleted         @map("deleted")
}

enum ArtifactRevisionState {
  Published       @map("published")
  DeletionPending @map("deletion_pending")
  Purged          @map("purged")
}

enum ArtifactIndexState {
  Pending        @map("pending")
  Indexed        @map("indexed")
  Failed         @map("failed")
  RemovalPending @map("removal_pending")
  Removed        @map("removed")
}

enum ArtifactOutboxEventKind {
  RevisionPublished @map("artifact.revision_published")
  SharingChanged    @map("artifact.sharing_changed")
  DeletionRequested @map("artifact.deletion_requested")
}

enum ArtifactUploadLeaseState {
  Active    @map("active")
  Promoted  @map("promoted")
  Finalized @map("finalized")
  Expired   @map("expired")
  Cancelled @map("cancelled")
}

model Artifact {
  id                String         @id @default(cuid())
  siloId            String         @map("silo_id")
  ownerPrincipalId  String         @map("owner_principal_id")
  kind              ArtifactKind
  state             ArtifactState  @default(Active)
  currentRevisionId String?        @map("current_revision_id")
  retentionPolicy   String         @default("until_authorized_deletion") @map("retention_policy")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  revisions         ArtifactRevision[] @relation("ArtifactRevisions")
  uploadLeases      ArtifactUploadLease[]
  currentRevision   ArtifactRevision?  @relation("CurrentArtifactRevision", fields: [id, currentRevisionId], references: [artifactId, id], onDelete: Restrict)

  @@unique([id, currentRevisionId])
  @@unique([id, siloId])
  @@index([siloId, ownerPrincipalId, state])
  @@map("artifacts")
}

model ArtifactUploadLease {
  id                      String                   @id @default(cuid())
  artifactId              String                   @map("artifact_id")
  siloId                  String                   @map("silo_id")
  capabilityJti           String                   @unique @map("capability_jti")
  expectedContentAddress  String?                  @map("expected_content_address")
  expectedByteLength      BigInt?                  @map("expected_byte_length")
  mediaType               String                   @map("media_type")
  state                   ArtifactUploadLeaseState @default(Active)
  expiresAt               DateTime                 @map("expires_at")
  promotionReceiptDigest  String?                  @unique @map("promotion_receipt_digest")
  promotedContentAddress  String?                  @map("promoted_content_address")
  promotedByteLength      BigInt?                  @map("promoted_byte_length")
  promotedAt              DateTime?                @map("promoted_at")
  finalizedAt             DateTime?                @map("finalized_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  artifact                Artifact                 @relation(fields: [artifactId], references: [id], onDelete: Restrict)

  @@index([artifactId, state, expiresAt])
  @@index([siloId, state, expiresAt])
  @@map("artifact_upload_leases")
}

model ArtifactRevision {
  id                String                @id @default(cuid())
  artifactId        String                @map("artifact_id")
  revision          Int
  state             ArtifactRevisionState @default(Published)
  contentAddress    String                @map("content_address")
  byteLength        BigInt                @map("byte_length")
  mediaType         String                @map("media_type")
  provenance        Json
  sourceRunId       String?               @map("source_run_id")
  sourceMessageId   String?               @map("source_message_id")
  indexState        ArtifactIndexState    @default(Pending) @map("index_state")
  cogneeExternalId  String?               @map("cognee_external_id")
  createdBy         String                @map("created_by")
  createdAt         DateTime              @default(now()) @map("created_at")
  deletionRequestedAt DateTime?           @map("deletion_requested_at")
  purgedAt          DateTime?              @map("purged_at")
  artifact          Artifact               @relation("ArtifactRevisions", fields: [artifactId], references: [id], onDelete: Restrict)
  currentFor        Artifact[]             @relation("CurrentArtifactRevision")
  parents           ArtifactRevisionParent[] @relation("ArtifactRevisionChildren")
  children          ArtifactRevisionParent[] @relation("ArtifactRevisionParents")
  outboxEvents      ArtifactOutboxEvent[]

  @@unique([artifactId, revision])
  @@unique([artifactId, id])
  @@unique([id, contentAddress])
  @@index([contentAddress, state])
  @@index([sourceRunId])
  @@index([indexState, createdAt])
  @@map("artifact_revisions")
}

model ArtifactRevisionParent {
  childRevisionId  String           @map("child_revision_id")
  parentRevisionId String           @map("parent_revision_id")
  child             ArtifactRevision @relation("ArtifactRevisionChildren", fields: [childRevisionId], references: [id], onDelete: Restrict)
  parent            ArtifactRevision @relation("ArtifactRevisionParents", fields: [parentRevisionId], references: [id], onDelete: Restrict)

  @@id([childRevisionId, parentRevisionId])
  @@index([parentRevisionId])
  @@map("artifact_revision_parents")
}

model ArtifactOutboxEvent {
  id             String                  @id @default(cuid())
  artifactId     String                  @map("artifact_id")
  revisionId     String                  @map("revision_id")
  kind           ArtifactOutboxEventKind
  idempotencyKey String                  @unique @map("idempotency_key")
  payload        Json
  availableAt    DateTime                @default(now()) @map("available_at")
  claimedAt      DateTime?               @map("claimed_at")
  publishedAt    DateTime?               @map("published_at")
  deliveryCount  Int                     @default(0) @map("delivery_count")
  createdAt      DateTime                @default(now()) @map("created_at")
  revision       ArtifactRevision        @relation(fields: [artifactId, revisionId], references: [artifactId, id], onDelete: Restrict)

  @@index([publishedAt, availableAt])
  @@map("artifact_outbox_events")
}
