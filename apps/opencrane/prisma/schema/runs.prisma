enum AgentRunTrigger {
  Interactive       @map("interactive")
  Schedule          @map("schedule")
  ManagedInvocation @map("managed_invocation")
}

enum AgentRunState {
  Accepted           @map("accepted")
  Queued             @map("queued")
  Assigned           @map("assigned")
  Running            @map("running")
  WaitingForApproval @map("waiting_for_approval")
  Completed          @map("completed")
  Failed             @map("failed")
  Cancelled          @map("cancelled")
}

enum AgentRunTerminalReason {
  Success         @map("success")
  UserCancelled   @map("user_cancelled")
  PolicyDenied    @map("policy_denied")
  BudgetExhausted @map("budget_exhausted")
  RuntimeFailure  @map("runtime_failure")
  InvalidInput    @map("invalid_input")
}

enum WorkloadAssignmentState {
  PendingPod @map("pending_pod")
  Registered @map("registered")
  Revoked    @map("revoked")
}

enum WorkloadKind {
  Job        @map("job")
  Deployment @map("deployment")
}

enum RunOutboxEventKind {
  RunAccepted              @map("run.accepted")
  RunAttemptRequested      @map("run.attempt_requested")
  RunCancellationRequested @map("run.cancellation_requested")
  RunResumeRequested       @map("run.resume_requested")
}

/// One logical run authority. Retries atomically increment `attempt`; there is no AgentRunAttempt.
model AgentRun {
  id                      String                   @id @default(cuid())
  siloId                  String                   @map("silo_id")
  agentServiceId          String                   @map("agent_service_id")
  agentRevisionId         String                   @map("agent_revision_id")
  threadId                String?                  @map("thread_id")
  trigger                 AgentRunTrigger
  delegatedUserId         String?                  @map("delegated_user_id")
  requestIdempotencyKey   String                   @map("request_idempotency_key")
  rootRunId               String                   @map("root_run_id")
  parentRunId             String?                  @map("parent_run_id")
  attempt                 Int                      @default(1)
  state                   AgentRunState            @default(Accepted)
  effectiveContractDigest String                   @map("effective_contract_digest")
  inputSnapshotDigest     String                   @map("input_snapshot_digest")
  acceptedAt              DateTime                 @default(now()) @map("accepted_at")
  startedAt               DateTime?                @map("started_at")
  finishedAt              DateTime?                @map("finished_at")
  terminalReason          AgentRunTerminalReason?  @map("terminal_reason")
  costAmount              Decimal?                 @map("cost_amount") @db.Decimal(18, 6)
  costCurrency            String?                  @map("cost_currency")
  revision                AgentRevision            @relation(fields: [agentServiceId, agentRevisionId], references: [agentServiceId, id], onDelete: Restrict)
  service                 AgentService             @relation(fields: [agentServiceId, siloId], references: [id, siloId], onDelete: Restrict)
  inputSnapshot           RunInputSnapshot?
  workloadAssignments     WorkloadAssignment[]
  proofKeys               RunProofKey[]
  approvalRequests        ApprovalRequest[]
  executionReceipts       ActionExecutionReceipt[]
  outboxEvents            OutboxEvent[]

  @@unique([siloId, requestIdempotencyKey])
  @@unique([id, agentServiceId, agentRevisionId])
  @@unique([id, siloId, agentServiceId, agentRevisionId])
  @@unique([id, agentRevisionId])
  @@unique([id, inputSnapshotDigest])
  @@unique([id, inputSnapshotDigest, threadId, siloId, agentServiceId, agentRevisionId, effectiveContractDigest], map: "agent_run_snapshot_identity_key")
  @@index([agentServiceId, state])
  @@index([threadId, acceptedAt])
  @@index([rootRunId])
  @@map("agent_runs")
}

model RunInputSnapshot {
  id                      String   @id @default(cuid())
  runId                   String   @unique @map("run_id")
  snapshotVersion         Int      @map("snapshot_version")
  siloId                  String   @map("silo_id")
  agentServiceId          String   @map("agent_service_id")
  agentRevisionId         String   @map("agent_revision_id")
  effectiveContractDigest String   @map("effective_contract_digest")
  personaRevisionId       String?  @map("persona_revision_id")
  threadId                String?  @map("thread_id")
  messageIds              String[] @default([]) @map("message_ids")
  preferenceFactIds       String[] @default([]) @map("preference_fact_ids")
  artifactRevisionIds     String[] @default([]) @map("artifact_revision_ids")
  memoryFacts             Json     @map("memory_facts")
  identitySnapshot        Json     @map("identity_snapshot")
  modelRoute              Json     @map("model_route")
  toolGrantIds            String[] @default([]) @map("tool_grant_ids")
  skillRevisionIds        String[] @default([]) @map("skill_revision_ids")
  memoryQueryPolicy       Json     @map("memory_query_policy")
  budgetPolicy            Json     @map("budget_policy")
  capabilitySetDigest     String   @map("capability_set_digest")
  promptCompilerVersion   String   @map("prompt_compiler_version")
  digest                  String   @unique @map("input_digest")
  compiledAt              DateTime @default(now()) @map("created_at")
  run                     AgentRun? @relation(fields: [runId, digest, threadId, siloId, agentServiceId, agentRevisionId, effectiveContractDigest], references: [id, inputSnapshotDigest, threadId, siloId, agentServiceId, agentRevisionId, effectiveContractDigest], onDelete: Restrict)

  @@unique([runId, digest])
  @@unique([runId, digest, threadId, siloId, agentServiceId, agentRevisionId, effectiveContractDigest], map: "run_input_snapshot_run_identity_key")
  @@index([agentServiceId, agentRevisionId])
  @@map("run_input_snapshots")
}

model WorkloadAssignment {
  runId              String                   @map("run_id")
  attempt            Int
  agentServiceId     String                   @map("agent_service_id")
  agentRevisionId    String                   @map("agent_revision_id")
  siloId             String                   @map("silo_id")
  subjectId          String                   @map("subject_id")
  audience           String
  serviceAccountName String                   @map("service_account_name")
  namespace          String
  workloadKind       WorkloadKind             @map("workload_kind")
  workloadUid        String                   @map("workload_uid")
  podUid             String?                  @map("pod_uid")
  state              WorkloadAssignmentState  @default(PendingPod)
  expiresAt          DateTime                 @map("expires_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  registeredAt       DateTime?                @map("registered_at")
  revokedAt          DateTime?                @map("revoked_at")
  run                AgentRun                 @relation(fields: [runId, siloId, agentServiceId, agentRevisionId], references: [id, siloId, agentServiceId, agentRevisionId], onDelete: Restrict)
  bootstrap          WorkloadBootstrap?
  proofKey           RunProofKey?
  executionReceipts  ActionExecutionReceipt[]
  approvalRequests   ApprovalRequest[]

  @@id([runId, attempt])
  @@unique([runId, attempt, agentServiceId, agentRevisionId, siloId, subjectId, audience, serviceAccountName, namespace, workloadKind, workloadUid], map: "workload_assignment_bootstrap_identity_key")
  @@unique([runId, attempt, agentServiceId, agentRevisionId, siloId, subjectId, serviceAccountName, namespace, workloadKind, workloadUid], map: "workload_assignment_action_identity_key")
  @@unique([runId, attempt, workloadKind, workloadUid], map: "workload_assignments_run_attempt_workload_key")
  @@unique([runId, attempt, workloadKind, workloadUid, podUid], map: "workload_assignments_run_attempt_workload_pod_key")
  @@unique([namespace, workloadKind, workloadUid])
  @@unique([namespace, podUid])
  @@index([siloId, subjectId])
  @@index([state, expiresAt])
  @@map("workload_assignments")
}

model WorkloadBootstrap {
  id                 String             @id @default(cuid())
  runId              String             @map("run_id")
  attempt            Int
  agentServiceId     String             @map("agent_service_id")
  agentRevisionId    String             @map("agent_revision_id")
  siloId             String             @map("silo_id")
  subjectId          String             @map("subject_id")
  audience           String
  serviceAccountName String             @map("service_account_name")
  namespace          String
  workloadKind       WorkloadKind       @map("workload_kind")
  workloadUid        String             @map("workload_uid")
  claimDigest        String             @unique @map("claim_digest")
  expiresAt          DateTime           @map("expires_at")
  consumedAt         DateTime?          @map("consumed_at")
  consumedByPodUid   String?            @map("consumed_by_pod_uid")
  receiptId          String?            @unique @map("receipt_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  assignment         WorkloadAssignment @relation(fields: [runId, attempt, agentServiceId, agentRevisionId, siloId, subjectId, audience, serviceAccountName, namespace, workloadKind, workloadUid], references: [runId, attempt, agentServiceId, agentRevisionId, siloId, subjectId, audience, serviceAccountName, namespace, workloadKind, workloadUid], onDelete: Restrict)
  proofKey           RunProofKey?

  @@unique([runId, attempt])
  @@unique([runId, attempt, agentServiceId, agentRevisionId, siloId, subjectId, audience, serviceAccountName, namespace, workloadKind, workloadUid], map: "workload_bootstrap_assignment_identity_key")
  @@index([expiresAt])
  @@map("workload_bootstraps")
}

model RunProofKey {
  id                String                   @id @default(cuid())
  bootstrapId       String                   @unique @map("bootstrap_id")
  runId             String                   @map("run_id")
  attempt           Int
  workloadKind      WorkloadKind             @map("workload_kind")
  workloadUid       String                   @map("workload_uid")
  podUid            String                   @map("pod_uid")
  publicKeyJwk      Json                     @map("public_key_jwk")
  keyThumbprint     String                   @unique @map("key_thumbprint")
  expiresAt         DateTime                 @map("expires_at")
  revokedAt         DateTime?                @map("revoked_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  run               AgentRun                 @relation(fields: [runId], references: [id], onDelete: Restrict, map: "run_proof_keys_run_fkey")
  assignment        WorkloadAssignment       @relation(fields: [runId, attempt, workloadKind, workloadUid, podUid], references: [runId, attempt, workloadKind, workloadUid, podUid], onDelete: Restrict, map: "run_proof_keys_assignment_fkey")
  bootstrap         WorkloadBootstrap        @relation(fields: [bootstrapId], references: [id], onDelete: Restrict)
  approvalRequests  ApprovalRequest[]
  executionReceipts ActionExecutionReceipt[]

  @@unique([runId, attempt])
  @@unique([runId, attempt, workloadKind, workloadUid])
  @@unique([runId, attempt, workloadKind, workloadUid, podUid])
  @@unique([id, runId, attempt])
  @@unique([id, runId, attempt, keyThumbprint], map: "run_proof_key_bound_thumbprint_key")
  @@unique([id, runId, attempt, workloadKind, workloadUid, keyThumbprint, podUid], map: "run_proof_key_bound_pod_key")
  @@index([podUid])
  @@index([expiresAt])
  @@map("run_proof_keys")
}

/// Run-domain transactional outbox, committed atomically with AgentRun authority changes.
model OutboxEvent {
  id             String             @id @default(cuid())
  runId          String             @map("run_id")
  attempt        Int
  sequence       Int
  kind           RunOutboxEventKind
  idempotencyKey String             @unique @map("idempotency_key")
  payload        Json
  availableAt    DateTime           @default(now()) @map("available_at")
  claimedAt      DateTime?          @map("claimed_at")
  publishedAt    DateTime?          @map("published_at")
  failedAt       DateTime?          @map("failed_at")
  failureCode    String?            @map("failure_code")
  deliveryCount  Int                @default(0) @map("delivery_count")
  createdAt      DateTime           @default(now()) @map("created_at")
  run            AgentRun           @relation(fields: [runId], references: [id], onDelete: Restrict)

  @@unique([runId, sequence])
  @@index([publishedAt, availableAt])
  @@map("run_outbox_events")
}
