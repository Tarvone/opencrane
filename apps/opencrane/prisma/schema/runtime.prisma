/// Command kind durably minted onto one runtime command stream. The dispatch authority mints
/// `start_attempt` to begin an attempt, `resume_attempt` to feed control-plane-authorized deferred
/// tool results back into a paused attempt (carrying the current input generation), and
/// `cancel_attempt` as a positive stop signal the runtime acts on immediately.
enum RuntimeCommandKind {
  StartAttempt  @map("start_attempt")
  ResumeAttempt @map("resume_attempt")
  CancelAttempt @map("cancel_attempt")
}

/// Disposition of one ordered steering boundary claim. Exactly one disposition is recorded per
/// boundary and survives process death, so a reconnecting runtime never double-absorbs steering.
enum RuntimeSteeringDisposition {
  Absorbed @map("absorbed")
  Deferred @map("deferred")
}

/// Per-attempt durable authority for the runtime command stream. It owns the monotonic command
/// sequence, the server-owned lease fence, the runtime instance bound to the current stream, and
/// the accepted candidate ids. It is created lazily the first time a registered runtime Pod polls
/// its stream and is never edited from a non-owning domain; the dispatch adapter reloads and locks
/// the live WorkloadAssignment on every call rather than trusting a foreign-key snapshot.
model RuntimeCommandStream {
  runId                String                     @map("run_id")
  attempt              Int
  fence                Int                        @default(1)
  inputGeneration      Int                        @default(0) @map("input_generation")
  runtimeInstanceId    String?                    @map("runtime_instance_id")
  nextCommandSequence  Int                        @default(1) @map("next_command_sequence")
  acceptedCandidateIds String[]                   @default([]) @map("accepted_candidate_ids")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")
  commands             RuntimeDispatchedCommand[]

  @@id([runId, attempt])
  @@map("runtime_command_streams")
}

/// Ordered steering-boundary ledger for one attempt. The runtime claims a boundary only at a safe
/// pre-model position, identified by a deterministic `boundaryId` derived from the run, attempt, and
/// the input generation it is advancing from. Recording is exactly-once: the primary key blocks a
/// second claim for the same boundary across process death, so on reconnect the prior disposition
/// (Absorbed or Deferred) is replayed rather than recomputed. Absorbing steering advances the input
/// generation; a model terminal tagged with a superseded generation is rejected as stale.
model RuntimeSteeringBoundary {
  runId               String                     @map("run_id")
  attempt             Int
  boundaryId          String                     @map("boundary_id")
  fromInputGeneration Int                        @map("from_input_generation")
  toInputGeneration   Int                        @map("to_input_generation")
  disposition         RuntimeSteeringDisposition
  steeringDigest      String?                    @map("steering_digest")
  claimedAt           DateTime                   @default(now()) @map("claimed_at")
  ackedAt             DateTime?                  @map("acked_at")

  @@id([runId, attempt, boundaryId])
  @@unique([runId, attempt, toInputGeneration])
  @@index([runId, attempt])
  @@map("runtime_steering_boundaries")
}

/// Latest subordinate runtime checkpoint for one attempt. The runtime writes an encrypted, version-
/// tagged snapshot of its in-memory loop state; the control plane stores only the ciphertext and its
/// version, never plaintext. Exactly one row exists per attempt (replaced in place on every write),
/// because a checkpoint is a resume optimisation that is always subordinate to canonical run
/// authority — it is discarded whenever its `inputGeneration` disagrees with the live attempt.
model RuntimeAttemptCheckpoint {
  runId             String   @map("run_id")
  attempt           Int
  checkpointVersion Int      @map("checkpoint_version")
  inputGeneration   Int      @map("input_generation")
  cipherVersion     String   @map("cipher_version")
  encryptedState    Bytes    @map("encrypted_state")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@id([runId, attempt])
  @@index([runId, attempt])
  @@map("runtime_attempt_checkpoints")
}

/// One durably minted command dispatched to the runtime. The rows for an attempt are exactly the
/// authority's accepted command-id set, and `(runId, attempt, sequence)` is strictly monotonic so a
/// reconnecting runtime can be re-sent an already-accepted command without the sequence advancing.
model RuntimeDispatchedCommand {
  id        String               @id @default(cuid())
  runId     String               @map("run_id")
  attempt   Int
  sequence  Int
  commandId String               @unique @map("command_id")
  kind      RuntimeCommandKind
  fence     Int
  issuedAt  DateTime             @map("issued_at")
  expiresAt DateTime             @map("expires_at")
  createdAt DateTime             @default(now()) @map("created_at")
  stream    RuntimeCommandStream @relation(fields: [runId, attempt], references: [runId, attempt], onDelete: Restrict)

  @@unique([runId, attempt, sequence])
  @@index([runId, attempt])
  @@map("runtime_dispatched_commands")
}
