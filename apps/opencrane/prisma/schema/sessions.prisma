/// Legacy session-to-scope rows retained only until the target schema deletes this model.
///
/// Phase A removed every writer, API, client, and runtime consumer. These rows have no current
/// authorization or anti-spill effect and are not an input to the target schema. There is no Tenant
/// foreign key because the historical principal could be either a tenant or a user.
model SessionScope {
  /// OpenClaw chat-window session key (the binding's identity).
  sessionKey String   @id @map("session_key")
  /// Historical tenant/user principal recorded by the retired writer.
  principal  String
  /// Historical scope selectors recorded by the retired writer.
  scopes     Json
  /// When the binding was first created.
  createdAt  DateTime @default(now()) @map("created_at")
  /// When the binding was last updated.
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([principal])
  @@map("session_scopes")
}
