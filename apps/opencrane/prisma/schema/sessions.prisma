/// Legacy session-to-scope rows retained read-only as R3 migration input.
///
/// Phase A removed every writer, API, client, and runtime consumer. These rows have no current
/// authorization or anti-spill effect; green migration may inspect them when reconstructing
/// historical scope intent, then R10 deletes the model. There is no Tenant foreign key because
/// the historical principal could be either a tenant or a user.
model SessionScope {
  /// OpenClaw chat-window session key (the binding's identity).
  sessionKey String   @id @map("session_key")
  /// Historical tenant/user principal recorded by the retired writer.
  principal  String
  /// Historical scope selectors recorded by the retired writer.
  scopes     Json
  /// When the binding was first created.
  createdAt  DateTime @default(now()) @map("created_at")
  /// When the binding was last updated.
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([principal])
  @@map("session_scopes")
}
