enum SkillState {
  Active  @map("active")
  Retired @map("retired")
}

enum SkillRevisionState {
  Draft     @map("draft")
  Review    @map("review")
  Published @map("published")
  Rejected  @map("rejected")
  Revoked   @map("revoked")
}

enum SkillTrustClass {
  ReviewedInstructions @map("reviewed_instructions")
  SandboxedPython      @map("sandboxed_python")
}

model Skill {
  id                String       @id @default(cuid())
  siloId            String       @map("silo_id")
  ownerPrincipalId  String       @map("owner_principal_id")
  name              String
  description       String       @default("")
  state             SkillState   @default(Active)
  currentRevisionId String?      @map("current_revision_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  revisions         SkillRevision[] @relation("SkillRevisions")
  currentRevision   SkillRevision?  @relation("CurrentSkillRevision", fields: [id, currentRevisionId], references: [skillId, id], onDelete: Restrict)

  @@unique([id, currentRevisionId])
  @@unique([siloId, ownerPrincipalId, name])
  @@index([siloId, state])
  @@map("skills")
}

model SkillRevision {
  id                     String             @id @default(cuid())
  skillId                String             @map("skill_id")
  revision               Int
  state                  SkillRevisionState @default(Draft)
  artifactId             String             @map("artifact_id")
  artifactRevisionId     String             @map("artifact_revision_id")
  artifactContentAddress String             @map("artifact_content_address")
  manifest               Json
  requirements           Json
  testReport             Json?              @map("test_report")
  scanResult             Json?              @map("scan_result")
  trustClass             SkillTrustClass    @map("trust_class")
  signature              String?
  signerKeyId            String?            @map("signer_key_id")
  authoredBy             String             @map("authored_by")
  reviewedBy             String?            @map("reviewed_by")
  createdAt              DateTime           @default(now()) @map("created_at")
  publishedAt            DateTime?          @map("published_at")
  revokedAt              DateTime?          @map("revoked_at")
  skill                  Skill              @relation("SkillRevisions", fields: [skillId], references: [id], onDelete: Restrict)
  currentFor             Skill[]            @relation("CurrentSkillRevision")

  @@unique([skillId, revision])
  @@unique([skillId, id])
  @@unique([id, artifactRevisionId, artifactContentAddress])
  @@index([artifactRevisionId])
  @@index([state, trustClass])
  @@map("skill_revisions")
}
