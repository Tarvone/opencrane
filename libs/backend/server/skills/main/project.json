{
  "name": "backend-server-skills",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/backend/server/skills/main/src",
  "tags": [
    "type:lib",
    "layer:backend",
    "scope:skills"
  ],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "libs/backend/server/skills/main"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "libs/backend/server/skills/main"
      }
    },
    "test:sql": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh ../../../../../scripts/run-postgres-authority-tests.sh tests/skill-authority.sql",
        "cwd": "libs/backend/server/skills/main"
      }
    }
  }
}
